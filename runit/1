#!/bin/sh


echo "[stage 1] mounting filesystems..."
mount -t proc proc /proc
mount -t sysfs sysfs /sys
mount -t devtmpfs devtmpfs /dev
mkdir -p /dev/pts
mount -t devpts devpts /dev/pts
mount -t tmpfs tmpfs /run
mkdir -p /run/udev
if [ -d /sys/firmware/efi ]; then
    mount -t efivarfs efivarfs /sys/firmware/efi/efivars
fi
mkdir -p /var/run/dbus
mkdir -p /run/user
touch /run/utmp
touch /run/utmp
ln -sf /run/utmp /var/run/utmp 2>/dev/null || true

echo "[stage 1] loading modules..."
modprobe i915

echo "[stage 1] setting hostname..."
hostname -F /etc/hostname

for type in rsa ecdsa ed25519; do
    if [ ! -f /etc/ssh/ssh_host_${type}_key ]; then
        ssh-keygen -t $type -f /etc/ssh/ssh_host_${type}_key -N ""
    fi
done

export SVDIR=/etc/sv

echo "[stage 1] bringing up loopback..."
ip link set lo up

# Register sysroot packages in flux database on first boot
/usr/bin/flux-bootstrap.sh

# Load AZERTY keymap
loadkmap < /etc/keymaps/fr-azerty.bmap || true

echo "[stage 1] done"
